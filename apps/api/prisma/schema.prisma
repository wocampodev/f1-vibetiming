generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionType {
  PRACTICE_1
  PRACTICE_2
  PRACTICE_3
  QUALIFYING
  SPRINT_QUALIFYING
  SPRINT
  RACE
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
}

enum IngestionKind {
  CALENDAR
  RESULTS
  STANDINGS
}

enum IngestionStatus {
  SUCCESS
  FAILED
}

enum LiveCaptureSource {
  PROVIDER
  SIMULATOR
}

enum LiveCaptureRunStatus {
  ACTIVE
  COMPLETED
  INTERRUPTED
}

model Team {
  id                   String                 @id @default(cuid())
  externalId           String                 @unique
  name                 String
  nationality          String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  drivers              Driver[]
  results              SessionResult[]
  constructorStandings ConstructorStanding[]
}

model Driver {
  id              String           @id @default(cuid())
  externalId      String           @unique
  code            String?
  number          Int?
  givenName       String
  familyName      String
  nationality     String?
  teamId          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  team            Team?            @relation(fields: [teamId], references: [id])
  results         SessionResult[]
  driverStandings DriverStanding[]
}

model Event {
  id            String    @id @default(cuid())
  externalId    String    @unique
  season        Int
  round         Int
  name          String
  circuitName   String
  locality      String?
  country       String?
  raceStartTime DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]

  @@unique([season, round])
}

model Session {
  id          String         @id @default(cuid())
  externalId  String         @unique
  eventId     String
  type        SessionType
  name        String
  startsAt    DateTime
  status      SessionStatus  @default(SCHEDULED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  results     SessionResult[]

  @@index([eventId, startsAt])
}

model SessionResult {
  id              String    @id @default(cuid())
  sessionId       String
  driverId        String
  teamId          String?
  position        Int?
  grid            Int?
  points          Float?
  laps            Int?
  status          String?
  time            String?
  q1              String?
  q2              String?
  q3              String?
  fastestLapTime  String?
  fastestLapRank  Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  driver          Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  team            Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([sessionId, driverId])
}

model DriverStanding {
  id         String   @id @default(cuid())
  season     Int
  round      Int
  position   Int
  points     Float
  wins       Int
  driverId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([season, round, driverId])
  @@index([season, round, position])
}

model ConstructorStanding {
  id         String   @id @default(cuid())
  season     Int
  round      Int
  position   Int
  points     Float
  wins       Int
  teamId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([season, round, teamId])
  @@index([season, round, position])
}

model IngestionRun {
  id               String          @id @default(cuid())
  kind             IngestionKind
  status           IngestionStatus
  startedAt        DateTime
  finishedAt       DateTime
  recordsProcessed Int             @default(0)
  errorMessage     String?
  season           Int?
}

model LiveCaptureRun {
  id             String               @id @default(cuid())
  source         LiveCaptureSource
  sessionKey     String?
  weekendId      String?
  sessionId      String?
  sessionName    String?
  status         LiveCaptureRunStatus @default(ACTIVE)
  startedAt      DateTime             @default(now())
  lastEventAt    DateTime?
  finishedAt     DateTime?
  eventsCaptured Int                  @default(0)
  decodeErrors   Int                  @default(0)
  lastTopic      String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  events         LiveProviderEvent[]
  snapshots      LiveSessionSnapshot[]

  @@index([source, status, startedAt])
  @@index([source, sessionKey, startedAt])
}

model LiveProviderEvent {
  id           String            @id @default(cuid())
  captureRunId String
  source       LiveCaptureSource
  sessionKey   String
  weekendId    String?
  sessionId    String?
  sessionName  String?
  runSequence  Int
  rawTopic     String
  topic        String
  emittedAt    DateTime
  receivedAt   DateTime          @default(now())
  decodeError  Boolean           @default(false)
  payloadHash  String
  payload      Json
  changedFields Json
  createdAt    DateTime          @default(now())
  captureRun   LiveCaptureRun    @relation(fields: [captureRunId], references: [id], onDelete: Cascade)

  @@unique([captureRunId, runSequence])
  @@index([source, sessionKey, emittedAt])
  @@index([source, topic, emittedAt])
  @@index([receivedAt])
}

model LiveSessionSnapshot {
  id           String            @id @default(cuid())
  captureRunId String?
  source       LiveCaptureSource
  sessionKey   String
  weekendId    String?
  sessionId    String?
  sessionName  String?
  generatedAt  DateTime
  lastEventAt  DateTime?
  version      Int               @default(1)
  publicState  Json
  internalState Json
  changedFields Json
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  captureRun   LiveCaptureRun?   @relation(fields: [captureRunId], references: [id], onDelete: SetNull)

  @@unique([source, sessionKey])
  @@index([generatedAt])
  @@index([source, sessionName, generatedAt])
}

model LiveTopicSchemaCatalog {
  id               String            @id @default(cuid())
  source           LiveCaptureSource
  rawTopic         String
  topic            String
  shapeSignature   String
  topLevelKeys     Json
  fieldPaths       Json
  samplePayload    Json
  firstSeenAt      DateTime
  lastSeenAt       DateTime
  observations     Int               @default(1)
  decodeErrorCount Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([source, rawTopic, shapeSignature])
  @@index([source, topic, lastSeenAt])
}
