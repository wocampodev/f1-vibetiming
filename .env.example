API_PORT=4000
WEB_PORT=3000
F1_API_BASE_URL=http://localhost:4000/api

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/f1_vibetiming?schema=public

ERGAST_BASE_URL=https://api.jolpi.ca/ergast

LIVE_SOURCE=provider
LIVE_SIGNALR_BASE_URL=https://livetiming.formula1.com/signalr
LIVE_SIGNALR_HUB=streaming
LIVE_SIGNALR_TOPICS=SessionInfo,SessionStatus,LapCount,TrackStatus,DriverList,TimingData,TimingAppData,RaceControlMessages,ExtrapolatedClock
LIVE_SIGNALR_RECONNECT_MIN_MS=1000
LIVE_SIGNALR_RECONNECT_MAX_MS=30000
LIVE_HEARTBEAT_MS=15000

# Optional local-dev simulator tuning (used only when LIVE_SOURCE=simulator)
LIVE_SIMULATOR_TICK_MS=2000
LIVE_SIMULATOR_SPEED_MULTIPLIER=1
LIVE_SIMULATOR_SEED=2026
