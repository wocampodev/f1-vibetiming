API_PORT=4000
WEB_PORT=3000
F1_API_BASE_URL=http://localhost:4000/api

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/f1_vibetiming?schema=public

ERGAST_BASE_URL=https://api.jolpi.ca/ergast

LIVE_SIGNALR_BASE_URL=https://livetiming.formula1.com/signalr
LIVE_SIGNALR_HUB=streaming
LIVE_SIGNALR_TOPICS=SessionInfo,SessionStatus,LapCount,TrackStatus,DriverList,TimingData,TimingStats,TimingAppData,CarData.z,Position.z,RaceControlMessages,ExtrapolatedClock
LIVE_SIGNALR_RECONNECT_MIN_MS=1000
LIVE_SIGNALR_RECONNECT_MAX_MS=30000
LIVE_HEARTBEAT_MS=15000
LIVE_PROVIDER_LOG=off
LIVE_PROVIDER_LOG_MAX_CHARS=600
LIVE_PROVIDER_CAPTURE_ENABLED=true
LIVE_PROVIDER_RAW_RETENTION_DAYS=30
LIVE_PROVIDER_SNAPSHOT_RETENTION_DAYS=30
LIVE_PROVIDER_SNAPSHOT_RESTORE_MAX_AGE_SEC=21600

# Local PostgreSQL backup schedule for docker compose
POSTGRES_BACKUP_SCHEDULE_CRON=15 3 * * *
POSTGRES_BACKUP_RETENTION_DAYS=30
POSTGRES_BACKUP_TZ=UTC
